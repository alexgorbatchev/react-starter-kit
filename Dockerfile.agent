# Use slim node image for a much smaller footprint (~250MB vs ~1.2GB)
FROM node:22-bookworm-slim

# Install bun
RUN npm install -g bun@1.3.11

WORKDIR /app

COPY package.json bun.lock ./
COPY apps/web/package.json apps/web/
COPY apps/api/package.json apps/api/
COPY apps/app/package.json apps/app/
COPY packages/core/package.json packages/core/
COPY packages/ui/package.json packages/ui/
COPY packages/typescript-config/package.json packages/typescript-config/
COPY apps/email/package.json apps/email/
COPY db/package.json db/
COPY scripts/package.json scripts/

# Use BuildKit cache to avoid redownloading packages every build
RUN --mount=type=cache,target=/root/.bun/install/cache bun install --ignore-scripts

COPY . .
ENV TIMEOUT_MS=30000
ENTRYPOINT ["bun", "run", "scripts/dev-agent-proxy.ts"]
