{
  "extends": "../packages/typescript-config/node.jsonc",
  "compilerOptions": {
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "types": ["bun", "node"]
  },
  "include": [
    "schema/**/*.ts",
    "seeds/**/*.ts",
    "scripts/**/*.ts",
    "*.ts",
    "*.json"
  ],
  "exclude": ["**/dist/**/*", "**/node_modules/**/*"]
}
